<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <!-- Metaetiquetas para SEO -->
    <meta name="description" content="Fundación Santa Catalina - Trabajamos para el bienestar de las mascotas y la comunidad en la provincia del Chaco, Argentina.">
    <meta name="keywords" content="fundación, mascotas, adopción, bienestar animal, ayuda, rescate, Chaco, Argentina">
    <meta name="author" content="Fundación Santa Catalina">
    <meta name="robots" content="index, follow">
    
    <!-- Open Graph para compartir en redes sociales -->
    <meta property="og:title" content="Fundación Santa Catalina">
    <meta property="og:description" content="Únete a nuestra causa y ayúdanos a mejorar la vida de los animales necesitados en Chaco, Argentina.">
    <meta property="og:image" content="{{ asset('img/logoCanva.png') }}">
    <meta property="og:url" content="{{ path('app_home') }}">
    <meta property="og:type" content="website">
    
    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Fundación Santa Catalina">
    <meta name="twitter:description" content="Trabajamos para el bienestar de los animales y la comunidad en Chaco, Argentina.">
    <meta name="twitter:image" content="{{ asset('img/logoCanva.png') }}">
    
    <title>{% block title %}Fundación Mascotas{% endblock %}</title>

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="{{ asset('css/bootstrap.min.css') }}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
    
    <!-- Estilos personalizados -->
    {% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/styles.css') }}">
    {% endblock %}
</head>

<body>
    {% block header %}
    <nav class="navbar navbar-expand-lg navbar-light navbar-custom sticky-top py-3">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-3" href="{{ path('app_home') }}">
                <img src="{{ asset('img/logoCanva.png') }}" alt="Fundación Sta Catalina" class="brand-logo">
                <span>Fundación Santa Catalina</span>
            </a>
        </div>
    </nav>
    {% endblock %}

    {% block body %}{% endblock %}

    {% block footer %}
    <footer class="site-footer text-center">
        <div class="container">
            <p class="mb-3 fw-semibold">&copy; {{ "now"|date("d/m/Y") }} Fundación Santa Catalina. Todos los derechos reservados.</p>
            <p class="mb-4">
                <span class="footer-pill">
                    <i class="fas fa-phone-alt"></i>
                    <a href="tel:+543624855001" class="text-decoration-none">+54 3624 855001</a>
                </span>
            </p>
            <div class="d-flex justify-content-center align-items-center flex-wrap gap-3">
                <a href="https://m.facebook.com/100087527208725/" target="_blank" rel="noopener" class="text-white">
                    <i class="fab fa-facebook fa-2x"></i>
                </a>
                <a href="https://www.instagram.com/fundacion_stacatalina" target="_blank" rel="noopener" class="text-white">
                    <i class="fab fa-instagram fa-2x"></i>
                </a>
                <a href="{{ asset('docs/estatuto.pdf') }}" class="btn btn-light d-inline-flex align-items-center gap-2" download>
                    <i class="fas fa-file-pdf"></i>
                    <span>Descargar Estatuto</span>
                </a>
            </div>
        </div>
    </footer>
    {% endblock %}

    <!-- Bootstrap JS y Popper -->
    <script src="{{ asset('js/bootstrap.bundle.min.js') }}"></script>

    {% block javascripts %}{% endblock %}
</body>
</html>
