{% extends 'base.html.twig' %}

{% block title %}Comunidad{% endblock %}

{% block body %}
<div class="container mt-4">

    <h1>{{ comunidad.titulo }}</h1>

    <table class="table table-bordered">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ comunidad.id }}</td>
            </tr>

            <tr>
                <th>Título</th>
                <td>{{ comunidad.titulo }}</td>
            </tr>

            <tr>
                <th>Descripción</th>
                <td>{{ comunidad.descripcion|nl2br }}</td>
            </tr>

            <tr>
                <th>Video</th>
                <td>
                    <a href="{{ comunidad.videoUrl }}" target="_blank">
                        {{ comunidad.videoUrl }}
                    </a>
                </td>
            </tr>

            <tr>
                <th>Miniatura</th>
                <td>
                    {% if comunidad.thumbnail %}
                        <a href="{{ comunidad.videoUrl }}" target="_blank">
                            <img
                                src="{{ asset('uploads/comunidad/' ~ comunidad.thumbnail) }}"
                                alt="{{ comunidad.titulo }}"
                                class="img-fluid rounded shadow"
                                style="max-width:400px;">
                        </a>
                    {% else %}
                        <span class="text-muted">No hay miniatura</span>
                    {% endif %}
                </td>
            </tr>

            <tr>
                <th>Incrustar video</th>
                <td>{{ comunidad.embed ? 'Sí' : 'No' }}</td>
            </tr>

            <tr>
                <th>Activo</th>
                <td>{{ comunidad.activo ? 'Sí' : 'No' }}</td>
            </tr>

            <tr>
                <th>Creado</th>
                <td>{{ comunidad.createdAt ? comunidad.createdAt|date('d/m/Y') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a class="btn btn-secondary" href="{{ path('app_comunidad_index') }}">
        Volver
    </a>

    <a class="btn btn-primary" href="{{ path('app_comunidad_edit', {'id': comunidad.id}) }}">
        Editar
    </a>

    {{ include('comunidad/_delete_form.html.twig') }}

</div>
{% endblock %}
